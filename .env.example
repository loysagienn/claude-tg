# Token from @BotFather
TELEGRAM_BOT_TOKEN=

# Secret phrase: send it to the bot to register your chat
TELEGRAM_PASSPHRASE=

# Optional
# Model the bot-spawned Claude sessions run on (passed as --model)
# SESSION_MODEL=claude-fable-5
# Path to the codex CLI for /agent → codex sessions (default ~/.local/bin/codex)
# CODEX_BIN=/home/claude/.local/bin/codex
# PORT=8765
# HOST=127.0.0.1
# CHAT_ID_FILE=chat-id.json
# BUTTON_ID_FILE=button-id.json
# SCHEDULES_FILE=schedules.json
# Where incoming photos/files the user sends to the bot are saved
# (absolute path — "~" is not expanded)
# DOWNLOAD_DIR=/home/claude/artifacts/claude-tg

# DigitalOcean Spaces — used to re-host photos before sending (sent to Telegram
# by URL). If unset here, they are read from ~/.claude/spaces.env; if still
# unavailable, photos are uploaded to Telegram directly.
# SPACES_ENDPOINT=https://<bucket>.<region>.digitaloceanspaces.com
# SPACES_REGION=ams3
# SPACES_BUCKET_NAME=<bucket>
# SPACES_ACCESS_KEY_ID=
# SPACES_ACCESS_KEY_SECRET=
